---
// ⚠️ Photos de démonstration (Unsplash). À remplacer par les vraies photos
// du restaurant (Instagram @tabledesgourmets) avant mise en production.
const photos = [
  '1559339352-11d035aa65de',
  '1600891964599-f61ba0e24092',
  '1424847651672-bf20a4b0982b',
  '1546833999-b9f581a1996d',
  '1504674900247-0877df9cc836',
  '1540189549336-e6e99c3679fe',
  '1551782450-a2132b4ba21d',
  '1432139509613-5c4255815697',
];
const src = (id: string) =>
  `https://images.unsplash.com/photo-${id}?w=600&q=75&auto=format&fit=crop`;
---

<section class="galerie section-pad" id="galerie">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">En images</p>
      <h2>L'atmosphère & <em>les assiettes</em></h2>
    </div>

    <div class="grid">
      {
        photos.map((id) => (
          <figure class="cell reveal">
            <img src={src(id)} alt="La Table des Gourmets" loading="lazy" />
          </figure>
        ))
      }
    </div>

    <div class="ig reveal">
      <a
        href="https://www.instagram.com/tabledesgourmets/"
        target="_blank"
        rel="noopener"
        class="btn btn-ghost"
      >
        Suivez-nous sur Instagram
      </a>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 200px;
    gap: 14px;
  }
  .cell {
    overflow: hidden;
    border-radius: 14px;
    background: var(--cream-deep);
  }
  /* Quelques cellules plus grandes pour un effet mosaïque */
  .cell:nth-child(1),
  .cell:nth-child(6) {
    grid-column: span 2;
    grid-row: span 2;
  }
  .cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .cell:hover img {
    transform: scale(1.06);
  }

  .ig {
    text-align: center;
    margin-top: clamp(28px, 4vw, 44px);
  }

  @media (max-width: 820px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 160px;
    }
    .cell:nth-child(1),
    .cell:nth-child(6) {
      grid-column: span 2;
      grid-row: span 1;
    }
  }
</style>
