---
// Galerie avec les vraies photos disponibles. Pour une immersion complète,
// ajouter des photos d'ambiance (salle, terrasse de jour, bar, cave à vins,
// dressage) dans public/images/ et les lister ici.
const photos = [
  { f: 'facade-nuit.png', alt: 'La terrasse en soirée', big: true },
  {
    f: 'jambonneau-braise-a-la.jpg',
    alt: 'Jambonneau braisé à la bière — le plat signature',
    big: true,
  },
  { f: 'foie-gras-de-canard.jpg', alt: 'Foie gras de canard' },
  { f: 'moelleux-au-chocolat.jpg', alt: 'Moelleux au chocolat' },
  { f: 'entrecote-grillee-pommes.jpg', alt: 'Entrecôte grillée' },
  { f: 'sole-meuniere-legumes.jpg', alt: 'Sole meunière' },
  { f: 'moules-gratinees-au-beurre.jpg', alt: 'Moules gratinées au beurre' },
  { f: 'confit-de-canard-gratin.jpg', alt: 'Confit de canard' },
];
---

<section class="galerie section-pad" id="galerie">
  <div class="container">
    <div class="section-head center reveal">
      <p class="eyebrow">En images</p>
      <h2>L'ambiance & <em>les assiettes</em></h2>
    </div>

    <div class="grid">
      {
        photos.map((p, i) => (
          <figure class={`cell ${p.big ? 'big' : ''} reveal`} style={`--d:${(i % 4) * 60}ms`}>
            <img src={`/images/${p.f}`} alt={p.alt} loading="lazy" />
          </figure>
        ))
      }
    </div>

    <div class="ig reveal">
      <a
        href="https://www.instagram.com/tabledesgourmets/"
        target="_blank"
        rel="noopener"
        class="btn btn-ghost">Voir plus de photos sur Instagram</a
      >
    </div>
  </div>
</section>

<style>
  .galerie {
    background: var(--cream-deep);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 210px;
    gap: 14px;
  }
  .cell {
    overflow: hidden;
    border-radius: 16px;
    background: var(--cream);
    box-shadow: var(--shadow-sm);
  }
  .cell.big {
    grid-column: span 2;
    grid-row: span 2;
  }
  .cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.55s ease;
  }
  .cell:hover img {
    transform: scale(1.06);
  }

  .ig {
    text-align: center;
    margin-top: clamp(28px, 4vw, 44px);
  }

  @media (max-width: 820px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 160px;
    }
    .cell.big {
      grid-column: span 2;
      grid-row: span 1;
    }
  }
</style>
