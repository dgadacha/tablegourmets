---
const { categories = [] } = Astro.props;
---

<div class="menu-list">
  {
    categories.map((c: any) => (
      <section class="menu-cat" id={c.id}>
        {!c.hideHead && (
          <div class="menu-cat-head">
            <h3>{c.label || c.cat}</h3>
          </div>
        )}
        {c.note && <p class="menu-note">{c.note}</p>}
        {c.items.map((it: any) => (
          <div class="menu-item">
            <div class="mi-line">
              <span class="mi-name">{it.name}</span>
              <span class="mi-leader" aria-hidden="true" />
              <span class="mi-price">{it.price} CFP</span>
            </div>
            {it.desc && <p class="mi-desc">{it.desc}</p>}
          </div>
        ))}
      </section>
    ))
  }
</div>

<style>
  .menu-list {
    max-width: 760px;
    margin-inline: auto;
  }
  .menu-cat {
    margin-bottom: 2.6rem;
    scroll-margin-top: 112px;
  }
  .menu-cat-head {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 0.8rem;
  }
  .menu-cat-head h3 {
    font-family: var(--font-serif);
    font-size: 1.55rem;
    color: var(--ink);
    white-space: nowrap;
  }
  .menu-cat-head::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--gold);
    opacity: 0.5;
  }
  .menu-note {
    font-size: 0.86rem;
    font-style: italic;
    color: var(--muted);
    margin-bottom: 0.9rem;
  }
  .menu-item {
    padding: 0.85rem 0;
  }
  .menu-item + .menu-item {
    border-top: 1px solid var(--line);
  }
  .mi-line {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .mi-name {
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--ink);
  }
  .mi-leader {
    flex: 1;
    border-bottom: 1px dotted var(--line);
    transform: translateY(-0.25em);
  }
  .mi-price {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--wine);
    white-space: nowrap;
  }
  .mi-desc {
    margin-top: 0.3rem;
    color: var(--muted);
    font-size: 0.95rem;
    max-width: 62ch;
  }
</style>
