---
// Plats photographiés au restaurant (vraies photos). Intitulés à faire valider.
const dishes = [
  {
    name: 'Foie gras de canard',
    desc: "L'entrée gastronomique de la maison.",
    img: 'foie-gras-de-canard.jpg',
  },
  {
    name: 'Foie de canard poêlé',
    desc: 'Saisi minute, fondant.',
    img: 'foie-de-canard-poele.jpg',
  },
  {
    name: 'Chèvre chaud & jambon cru',
    desc: 'Croûtons de chèvre, jambon cru et salade.',
    img: 'croutons-de-chevre-au.jpg',
  },
  {
    name: 'Entrecôte grillée',
    desc: 'Grillée, pommes de terre & garniture.',
    img: 'entrecote-grillee-pommes.jpg',
  },
  {
    name: 'Sole meunière',
    desc: 'Au beurre, légumes de saison.',
    img: 'sole-meuniere-legumes.jpg',
  },
  {
    name: 'Moules gratinées au beurre',
    desc: 'Beurre persillé, gratinées au four.',
    img: 'moules-gratinees-au-beurre.jpg',
  },
  {
    name: 'Confit de canard',
    desc: 'Cuisse confite & gratin maison.',
    img: 'confit-de-canard-gratin.jpg',
  },
  {
    name: 'Moelleux au chocolat',
    desc: 'Cœur coulant, le dessert signature.',
    img: 'moelleux-au-chocolat.jpg',
  },
];
---

<section class="carte section-pad" id="carte">
  <div class="container">
    <div class="section-head center reveal">
      <p class="eyebrow">La Carte</p>
      <h2>Nos plats <em>signatures</em></h2>
      <p class="lead">
        Cuisine française aux accents alsaciens et saveurs du Pacifique,
        renouvelée au fil des saisons. La carte du jour est toujours à
        l'ardoise.
      </p>
    </div>

    <article class="dish-feature reveal">
      <div class="feat-photo">
        <img
          src="/images/jambonneau-braise-a-la.jpg"
          alt="Jambonneau braisé à la bière"
          loading="lazy"
        />
      </div>
      <div class="feat-body">
        <span class="feat-label">Le plat signature</span>
        <h3>Jambonneau braisé à la bière</h3>
        <p>
          Un jarret de porc longuement braisé à la bière, fondant à cœur, servi
          avec lentilles et pommes de terre rôties.
        </p>
        <p class="feat-note">Servi du mardi au samedi, midi et soir.</p>
      </div>
    </article>

    <div class="dishes">
      {
        dishes.map((d, i) => (
          <article class="dish reveal" style={`--d:${(i % 3) * 80}ms`}>
            <div class="dish-photo">
              <img src={`/images/${d.img}`} alt={d.name} loading="lazy" />
            </div>
            <div class="dish-body">
              <h3>{d.name}</h3>
              <p>{d.desc}</p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="carte-cta reveal">
      <p>Suggestions du jour toujours à l'ardoise.</p>
      <div class="carte-actions">
        <a href="#infos" class="btn btn-primary btn-lg">Infos & contact</a>
        <a
          href="https://www.instagram.com/tabledesgourmets/"
          target="_blank"
          rel="noopener"
          class="btn btn-ghost">Plus de plats sur Instagram</a
        >
      </div>
    </div>
  </div>
</section>

<style>
  .carte {
    background: var(--cream);
  }

  /* Plat signature — grande carte asymétrique */
  .dish-feature {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: var(--shadow-card);
    margin-bottom: clamp(20px, 3vw, 34px);
  }
  .feat-photo {
    position: relative;
    min-height: 320px;
    overflow: hidden;
  }
  .feat-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .dish-feature:hover .feat-photo img {
    transform: scale(1.04);
  }
  .feat-body {
    padding: clamp(1.8rem, 4vw, 3.2rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .feat-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.9rem;
  }
  .feat-label::before {
    content: '';
    width: 26px;
    height: 2px;
    background: var(--gold);
  }
  .feat-body h3 {
    font-size: clamp(1.8rem, 3.5vw, 2.7rem);
    margin-bottom: 0.8rem;
  }
  .feat-body p {
    color: var(--ink-soft);
    font-size: 1.06rem;
  }
  .feat-note {
    margin-top: 1rem;
    color: var(--muted);
    font-size: 0.9rem;
    font-style: italic;
  }

  /* Grille des autres plats */
  .dishes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(18px, 2.4vw, 30px);
  }
  .dish {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .dish:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-card);
  }
  .dish-photo {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .dish-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.55s ease;
  }
  .dish:hover .dish-photo img {
    transform: scale(1.05);
  }
  .dish-body {
    padding: 1.3rem 1.4rem 1.6rem;
  }
  .dish-body h3 {
    font-size: 1.45rem;
    margin-bottom: 0.4rem;
  }
  .dish-body p {
    color: var(--muted);
    font-size: 1rem;
  }

  .carte-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-top: clamp(40px, 5vw, 60px);
    text-align: center;
  }
  .carte-cta p {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    color: var(--ink);
  }
  .carte-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: center;
  }

  @media (max-width: 760px) {
    .dish-feature {
      grid-template-columns: 1fr;
    }
    .feat-photo {
      min-height: 240px;
    }
  }
  @media (max-width: 820px) {
    .dishes {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .dishes {
      grid-template-columns: 1fr;
    }
  }
</style>
