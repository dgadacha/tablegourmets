---
import MenuList from './MenuList.astro';
import { feature, menu } from '../data/menu';

const get = (name: string) => menu.find((c) => c.cat === name)!;
const find = (cat: string, name: string) =>
  get(cat).items.find((i) => i.name === name);

// Aperçu représentatif (~11 plats) — le reste est dans la modal carte complète
const preview = [
  {
    cat: 'Les entrées',
    items: [
      find('Le foie gras', 'Foie gras de canard au Gewürztraminer'),
      find('Les entrées', "Escargots de Bourgogne à l'ancienne"),
      find('Les entrées', 'Salade de croûtons de chèvre chauds'),
    ].filter(Boolean),
  },
  {
    cat: 'Nos plats',
    items: [
      find('Côté mer', "Filet de poisson du jour à l'huile d'olive"),
      find('Côté mer', 'Sole meunière'),
      find('Le coin du boucher', 'Cuisse de canard confite'),
      find('Le coin du boucher', "Entrecôte grillée, beurre maître d'hôtel"),
      find('La cuisine de nos régions', 'Cassoulet du Sud-Ouest'),
    ].filter(Boolean),
  },
  {
    cat: 'Les desserts',
    items: [
      find('Les desserts', 'Moelleux au chocolat mi-cuit'),
      find('Les desserts', 'Café gourmand'),
    ].filter(Boolean),
  },
];
---

<section class="carte section-pad" id="carte">
  <div class="container">
    <div class="section-head center reveal">
      <p class="eyebrow">La Carte</p>
      <h2>Nos <em>plats</em></h2>
      <p class="lead">
        Cuisine française aux accents alsaciens et saveurs du Pacifique,
        renouvelée au fil des saisons. Suggestions du jour à l'ardoise.
      </p>
    </div>

    <article class="dish-feature reveal">
      <div class="feat-photo">
        <img src={`/images/${feature.img}`} alt={feature.name} loading="lazy" />
      </div>
      <div class="feat-body">
        <span class="feat-label">Le plat signature</span>
        <h3>{feature.name}</h3>
        <p>{feature.desc}</p>
        <p class="feat-price">{feature.price} CFP</p>
      </div>
    </article>

    <div class="reveal">
      <MenuList categories={preview} />
    </div>

    <div class="carte-more reveal">
      <button type="button" id="carteOpen" class="btn btn-primary btn-lg">
        Voir la carte complète
      </button>
    </div>

    <p class="carte-foot reveal">
      Prix en francs Pacifique (CFP) · Cuisine faite maison
    </p>

    <div class="carte-cta reveal">
      <a
        href="https://www.instagram.com/tabledesgourmets/"
        target="_blank"
        rel="noopener"
        class="btn btn-ghost">Plus de plats sur Instagram</a
      >
    </div>
  </div>
</section>

<dialog id="carteModal" class="carte-modal" aria-label="Carte complète">
  <div class="cm-top">
    <div class="cm-head">
      <h2>La Carte</h2>
      <button type="button" id="carteClose" class="cm-close" aria-label="Fermer la carte">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
          ><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg
        >
      </button>
    </div>
    <nav class="cm-nav" aria-label="Catégories de la carte">
      {
        menu.map((c, i) => (
          <button type="button" class="cm-tab" data-target={`cm-${i}`}>
            {c.cat}
          </button>
        ))
      }
    </nav>
  </div>
  <div class="cm-body">
    <MenuList categories={menu} idPrefix="cm-" />
    <p class="cm-foot">Prix en francs Pacifique (CFP) · Cuisine faite maison</p>
  </div>
</dialog>

<script>
  const openBtn = document.getElementById('carteOpen');
  const modal = document.getElementById('carteModal') as HTMLDialogElement | null;
  const closeBtn = document.getElementById('carteClose');

  const open = () => {
    modal?.showModal();
    document.body.style.overflow = 'hidden';
  };
  const close = () => {
    modal?.close();
    document.body.style.overflow = '';
  };

  openBtn?.addEventListener('click', open);
  closeBtn?.addEventListener('click', close);
  modal?.addEventListener('cancel', () => {
    document.body.style.overflow = '';
  });
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) close();
  });
  modal?.querySelectorAll('.cm-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const id = tab.getAttribute('data-target');
      if (id) {
        document
          .getElementById(id)
          ?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>

<style>
  .carte {
    background: var(--cream);
  }

  /* Plat signature — grande carte asymétrique */
  .dish-feature {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: var(--shadow-card);
    margin-bottom: clamp(40px, 5vw, 64px);
  }
  .feat-photo {
    position: relative;
    min-height: 320px;
    overflow: hidden;
  }
  .feat-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .dish-feature:hover .feat-photo img {
    transform: scale(1.04);
  }
  .feat-body {
    padding: clamp(1.8rem, 4vw, 3.2rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .feat-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.9rem;
  }
  .feat-label::before {
    content: '';
    width: 26px;
    height: 2px;
    background: var(--gold);
  }
  .feat-body h3 {
    font-size: clamp(1.8rem, 3.5vw, 2.7rem);
    margin-bottom: 0.8rem;
  }
  .feat-body p {
    color: var(--ink-soft);
    font-size: 1.06rem;
  }
  .feat-price {
    margin-top: 1.1rem;
    font-family: var(--font-serif);
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--wine) !important;
  }

  .carte-more {
    text-align: center;
    margin-top: clamp(28px, 4vw, 44px);
  }
  .carte-foot {
    text-align: center;
    margin-top: clamp(24px, 3vw, 36px);
    font-size: 0.86rem;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  .carte-cta {
    display: flex;
    justify-content: center;
    margin-top: 1.2rem;
  }

  /* Modal carte complète */
  .carte-modal {
    width: min(920px, 94vw);
    max-height: 90vh;
    padding: 0;
    border: 0;
    border-radius: 20px;
    background: var(--paper);
    color: var(--ink);
    overflow: hidden;
    box-shadow: var(--shadow);
    flex-direction: column;
  }
  .carte-modal[open] {
    display: flex;
  }
  .carte-modal::backdrop {
    background: rgba(20, 15, 12, 0.6);
    backdrop-filter: blur(2px);
  }
  .cm-top {
    flex: none;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
  }
  .cm-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem clamp(1.2rem, 3vw, 2rem);
  }
  .cm-head h2 {
    font-size: 1.9rem;
  }
  .cm-close {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: var(--cream);
    color: var(--ink);
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .cm-close:hover {
    background: var(--cream-deep);
  }
  .cm-nav {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding: 0 clamp(1.2rem, 3vw, 2rem) 0.9rem;
  }
  .cm-tab {
    flex: none;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink-soft);
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .cm-tab:hover {
    border-color: var(--gold);
    color: var(--ink);
  }
  .cm-body {
    flex: 1;
    overflow-y: auto;
    padding: clamp(1.4rem, 3vw, 2.4rem);
  }
  .cm-foot {
    text-align: center;
    margin-top: 1.6rem;
    font-size: 0.84rem;
    color: var(--muted);
  }

  @media (max-width: 760px) {
    .dish-feature {
      grid-template-columns: 1fr;
    }
    .feat-photo {
      min-height: 240px;
    }
    .carte-modal {
      width: 100vw;
      max-width: 100vw;
      max-height: 100vh;
      height: 100vh;
      border-radius: 0;
    }
  }
</style>
