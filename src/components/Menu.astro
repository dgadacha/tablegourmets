---
// Plats photographiés au restaurant (vraies photos fournies). Intitulés et
// descriptions à faire valider par le restaurant.
const dishes = [
  {
    cat: 'Entrée',
    name: 'Foie gras de canard',
    desc: "L'entrée gastronomique de la maison.",
    img: 'foie-gras-de-canard.jpg',
  },
  {
    cat: 'Entrée',
    name: 'Foie de canard poêlé',
    desc: 'Saisi minute, fondant.',
    img: 'foie-de-canard-poele.jpg',
  },
  {
    cat: 'Entrée',
    name: 'Chèvre chaud & jambon cru',
    desc: 'Croûtons de chèvre, jambon cru et salade.',
    img: 'croutons-de-chevre-au.jpg',
  },
  {
    cat: 'Signature',
    name: 'Jambonneau braisé à la bière',
    desc: 'Longuement braisé, lentilles & pommes de terre rôties.',
    img: 'jambonneau-braise-a-la.jpg',
  },
  {
    cat: 'Plat',
    name: 'Entrecôte grillée',
    desc: 'Grillée, pommes de terre & garniture.',
    img: 'entrecote-grillee-pommes.jpg',
  },
  {
    cat: 'Plat',
    name: 'Sole meunière',
    desc: 'Au beurre, légumes de saison.',
    img: 'sole-meuniere-legumes.jpg',
  },
  {
    cat: 'Plat',
    name: 'Moules gratinées au beurre',
    desc: 'Beurre persillé, gratinées au four.',
    img: 'moules-gratinees-au-beurre.jpg',
  },
  {
    cat: 'Plat',
    name: 'Confit de canard',
    desc: 'Cuisse confite & gratin maison.',
    img: 'confit-de-canard-gratin.jpg',
  },
  {
    cat: 'Dessert',
    name: 'Moelleux au chocolat',
    desc: 'Cœur coulant, le dessert signature.',
    img: 'moelleux-au-chocolat.jpg',
  },
];
---

<section class="carte section-pad" id="carte">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">La Carte</p>
      <h2>Quelques <em>signatures</em></h2>
      <p class="lead">
        Cuisine française aux accents alsaciens et saveurs du Pacifique,
        renouvelée au fil des saisons. La carte du jour est toujours à
        l'ardoise.
      </p>
    </div>

    <div class="dishes">
      {
        dishes.map((d) => (
          <article class="dish reveal">
            <div class="dish-photo">
              <img src={`/images/${d.img}`} alt={d.name} loading="lazy" />
              <span class="dish-cat">{d.cat}</span>
            </div>
            <div class="dish-body">
              <h3>{d.name}</h3>
              <p>{d.desc}</p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="carte-cta reveal">
      <p>Envie de découvrir la suggestion du jour&nbsp;?</p>
      <div class="carte-actions">
        <a href="tel:+687249525" class="btn btn-primary">Réserver une table</a>
        <a
          href="https://www.instagram.com/tabledesgourmets/"
          target="_blank"
          rel="noopener"
          class="btn btn-ghost">Plus de plats sur Instagram</a
        >
      </div>
    </div>
  </div>
</section>

<style>
  .carte {
    background: var(--cream-deep);
  }
  .lead {
    color: var(--ink-soft);
    font-size: 1.05rem;
    margin-top: 0.8rem;
  }

  .dishes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(18px, 2.4vw, 28px);
  }
  .dish {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 18px;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .dish:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
  }
  .dish-photo {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .dish-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .dish:hover .dish-photo img {
    transform: scale(1.06);
  }
  .dish-cat {
    position: absolute;
    top: 12px;
    left: 12px;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(192, 57, 43, 0.92);
    padding: 0.32rem 0.7rem;
    border-radius: 999px;
  }
  .dish-body {
    padding: 1.3rem 1.4rem 1.5rem;
  }
  .dish-body h3 {
    font-size: 1.45rem;
    margin-bottom: 0.4rem;
  }
  .dish-body p {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .carte-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-top: clamp(36px, 5vw, 56px);
    text-align: center;
  }
  .carte-cta p {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--ink);
  }
  .carte-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: center;
  }

  @media (max-width: 820px) {
    .dishes {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .dishes {
      grid-template-columns: 1fr;
    }
  }
</style>
