---
const hours = [
  { d: 'Mardi', h: '11h00 – 13h30 · 19h00 – 21h30' },
  { d: 'Mercredi', h: '11h00 – 13h30 · 19h00 – 21h30' },
  { d: 'Jeudi', h: '11h00 – 13h30 · 19h00 – 21h30' },
  { d: 'Vendredi', h: '11h00 – 13h30 · 19h00 – 21h30' },
  { d: 'Samedi', h: '11h00 – 13h30 · 19h00 – 21h30' },
  { d: 'Dimanche', h: 'Fermé', closed: true },
  { d: 'Lundi', h: 'Fermé', closed: true },
];
const mapSrc =
  'https://www.google.com/maps?q=91+Rue+Maurice+Herzog,+Noum%C3%A9a&output=embed';
---

<section class="infos section-pad" id="infos">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">Réserver & nous trouver</p>
      <h2>Une table vous <em>attend</em></h2>
    </div>

    <div class="infos-grid">
      <div class="infos-col reveal">
        <div class="info-block">
          <div class="info-row">
            <h3>Réservations</h3>
            <a href="tel:+687249525" class="phone">+687 24 95 25</a>
            <p class="hint">Réservation conseillée, par téléphone.</p>
          </div>

          <div class="info-row">
            <h3>Adresse</h3>
            <p>
              91 rue Maurice Herzog<br />
              Face au stade de Magenta<br />
              98800 Nouméa, Nouvelle-Calédonie
            </p>
          </div>

          <div class="info-row">
            <h3>Contact</h3>
            <p>
              <a href="mailto:direction@latabledesgourmets.com"
                >direction@latabledesgourmets.com</a
              >
            </p>
            <p class="services">
              <span>Sur place</span><span>À emporter</span><span>Terrasse</span>
            </p>
          </div>

          <a href="tel:+687249525" class="btn btn-primary big-cta"
            >Appeler pour réserver</a
          >
        </div>

        <div class="hours">
          <h3>Horaires</h3>
          <ul>
            {
              hours.map((row) => (
                <li class={row.closed ? 'closed' : ''}>
                  <span>{row.d}</span>
                  <span>{row.h}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="map reveal">
        <iframe
          title="Localisation de La Table des Gourmets à Nouméa"
          src={mapSrc}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .infos-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 4vw, 48px);
    align-items: stretch;
  }
  .infos-col {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .info-block,
  .hours {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: clamp(1.5rem, 3vw, 2.2rem);
  }
  .info-row {
    padding-bottom: 1.2rem;
    margin-bottom: 1.2rem;
    border-bottom: 1px solid var(--line);
  }
  .info-row h3 {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
    font-family: var(--font-sans);
    margin-bottom: 0.5rem;
  }
  .info-row p {
    color: var(--ink-soft);
  }
  .info-row a {
    color: var(--wine);
    font-weight: 500;
    word-break: break-word;
  }
  .phone {
    font-family: var(--font-serif);
    font-size: 1.9rem !important;
    font-weight: 600;
    color: var(--ink) !important;
  }
  .hint {
    font-size: 0.86rem;
    color: var(--muted);
    margin-top: 0.3rem;
  }
  .services {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.7rem;
  }
  .services span {
    font-size: 0.78rem;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    background: var(--cream-deep);
    color: var(--ink-soft);
  }
  .big-cta {
    width: 100%;
    justify-content: center;
    margin-top: 0.3rem;
  }

  .hours h3 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    margin-bottom: 0.9rem;
  }
  .hours ul {
    list-style: none;
  }
  .hours li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px dashed var(--line);
    font-size: 0.94rem;
  }
  .hours li:last-child {
    border-bottom: 0;
  }
  .hours li span:first-child {
    font-weight: 600;
    color: var(--ink);
  }
  .hours li span:last-child {
    color: var(--ink-soft);
    text-align: right;
  }
  .hours li.closed span:last-child {
    color: var(--wine);
    font-weight: 500;
  }

  .map {
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--line);
    min-height: 420px;
    box-shadow: var(--shadow-sm);
  }
  .map iframe {
    width: 100%;
    height: 100%;
    min-height: 420px;
    border: 0;
    display: block;
  }

  @media (max-width: 860px) {
    .infos-grid {
      grid-template-columns: 1fr;
    }
    .map {
      min-height: 320px;
      order: -1;
    }
  }
</style>
