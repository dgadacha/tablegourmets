---
const stats = [
  { value: '2009', label: 'Ouvert depuis' },
  { value: 'N°1', label: 'à Nouméa' },
  { value: '4,6/5', label: 'note moyenne' },
  { value: '570', label: 'avis clients' },
];
---

<section class="maison section-pad" id="maison">
  <div class="container">
    <div class="maison-grid">
      <div class="maison-media reveal">
        <img
          class="maison-photo"
          src="/images/terrasse.jpg"
          alt="La terrasse de La Table des Gourmets"
          loading="lazy"
        />
        <div class="maison-tag">
          <span>Depuis</span>
          <strong>2009</strong>
        </div>
      </div>

      <div class="maison-text reveal">
        <p class="eyebrow">Notre histoire</p>
        <h2>Une cuisine française <em>habitée</em>.</h2>
        <p>
          Depuis 2009, La Table des Gourmets célèbre la cuisine française au fil
          des saisons. Aux fourneaux, un chef d'origine alsacienne compose une
          carte renouvelée régulièrement, entre grands classiques et
          spécialités de sa région.
        </p>
        <p>
          Ici, pas une assiette ne quitte la cuisine sans l'œil du chef — une
          exigence qui vaut à la maison la <strong
            >première place des tables de Nouméa</strong
          >.
        </p>
      </div>
    </div>

    <div class="stats reveal">
      {
        stats.map((s) => (
          <div class="stat">
            <strong>{s.value}</strong>
            <span>{s.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .maison-grid {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(32px, 6vw, 80px);
    align-items: center;
  }

  .maison-media {
    position: relative;
  }
  .maison-photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 20px;
    box-shadow: var(--shadow);
  }
  .maison-tag {
    position: absolute;
    bottom: -22px;
    right: -10px;
    background: var(--brown);
    color: #fff;
    border-radius: 16px;
    padding: 0.9rem 1.4rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
  }
  .maison-tag span {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-soft);
  }
  .maison-tag strong {
    font-family: var(--font-serif);
    font-size: 1.9rem;
    line-height: 1;
  }

  .maison-text h2 {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    margin: 0.6rem 0 1.4rem;
  }
  .maison-text em {
    font-style: italic;
    color: var(--wine);
  }
  .maison-text p {
    color: var(--ink-soft);
    font-size: 1.06rem;
    margin-bottom: 1rem;
    max-width: 52ch;
  }
  .maison-text strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* Bande de chiffres — éditoriale, sans boîtes, séparateurs verticaux */
  .stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: clamp(48px, 6vw, 84px);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .stat {
    flex: 1 1 170px;
    text-align: center;
    padding: clamp(22px, 3vw, 36px) 1rem;
    border-left: 1px solid var(--line);
  }
  .stat:first-child {
    border-left: 0;
  }
  .stat strong {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 4.5vw, 3rem);
    line-height: 1;
    color: var(--wine);
  }
  .stat span {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
  }

  @media (max-width: 820px) {
    .maison-grid {
      grid-template-columns: 1fr;
    }
    .maison-media {
      max-width: 460px;
    }
    .maison-tag {
      right: 16px;
    }
  }
  @media (max-width: 600px) {
    .stat {
      flex-basis: 50%;
    }
    .stat:nth-child(3) {
      border-left: 0;
    }
  }
</style>
