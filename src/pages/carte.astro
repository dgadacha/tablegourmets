---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MobileBar from '../components/MobileBar.astro';
import MenuList from '../components/MenuList.astro';
import { menu } from '../data/menu';
---

<Layout
  title="La Carte — La Table des Gourmets"
  description="La carte complète de La Table des Gourmets à Nouméa : entrées, foie gras, côté mer, viandes, spécialités de nos régions, desserts. Prix en CFP."
>
  <Nav />
  <main>
    <header class="carte-hero">
      <div class="container">
        <p class="eyebrow">La Table des Gourmets</p>
        <h1>La Carte</h1>
        <p class="carte-hero-sub">
          Cuisine française aux accents alsaciens et saveurs du Pacifique. Prix
          en francs Pacifique (CFP).
        </p>
        <nav class="cat-nav" aria-label="Catégories de la carte">
          {menu.map((c, i) => <a href={`#cat-${i}`}>{c.cat}</a>)}
        </nav>
      </div>
    </header>

    <section class="carte-page section-pad">
      <div class="container">
        <MenuList categories={menu} idPrefix="cat-" />
        <p class="carte-foot">
          Cuisine faite maison · Suggestions du jour à l'ardoise
        </p>
        <div class="back">
          <a href="/#carte" class="btn btn-ghost">← Retour à l'accueil</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <MobileBar />
</Layout>

<style>
  .carte-hero {
    background: linear-gradient(150deg, var(--brown), #2f1d12);
    color: var(--cream);
    padding-top: clamp(120px, 16vh, 165px);
    padding-bottom: clamp(40px, 6vw, 64px);
    text-align: center;
  }
  .carte-hero :global(.eyebrow) {
    color: var(--gold-soft);
    justify-content: center;
  }
  .carte-hero :global(.eyebrow::before) {
    background: var(--gold);
  }
  .carte-hero h1 {
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    margin: 0.5rem 0 0.8rem;
  }
  .carte-hero-sub {
    color: rgba(247, 240, 227, 0.82);
    max-width: 560px;
    margin-inline: auto;
  }
  .cat-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-top: 1.8rem;
  }
  .cat-nav a {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--cream);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
    transition: background 0.2s ease;
  }
  .cat-nav a:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .carte-page {
    background: var(--cream);
  }
  .carte-foot {
    text-align: center;
    margin-top: clamp(28px, 4vw, 44px);
    color: var(--muted);
    font-size: 0.86rem;
    letter-spacing: 0.04em;
  }
  .back {
    text-align: center;
    margin-top: 1.8rem;
  }
</style>
