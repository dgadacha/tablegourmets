---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MobileBar from '../components/MobileBar.astro';
import MenuList from '../components/MenuList.astro';
import { menu } from '../data/menu';

const byId = (id: string) => menu.find((c) => c.id === id)!;

// Grands ensembles d'une vraie carte — sous-catégories regroupées.
// hideHead masque le sous-titre quand il ferait doublon avec le grand titre.
const groups = [
  {
    title: 'Entrées',
    cats: [{ ...byId('entrees'), hideHead: true }, byId('foie-gras')],
  },
  {
    title: 'Plats',
    cats: [byId('cote-mer'), byId('coin-boucher'), byId('regions')],
  },
  { title: 'Desserts', cats: [{ ...byId('desserts'), hideHead: true }] },
  { title: 'Coupes glacées', cats: [{ ...byId('coupes'), hideHead: true }] },
];
---

<Layout
  title="La Carte — La Table des Gourmets"
  description="La carte complète de La Table des Gourmets à Nouméa : entrées, foie gras, côté mer, viandes, spécialités de nos régions, desserts. Prix en CFP."
>
  <Nav />
  <main>
    <header class="carte-hero">
      <div class="container">
        <p class="eyebrow">La Table des Gourmets</p>
        <h1>Notre Carte</h1>
        <p class="carte-hero-sub">
          Les spécialités qui font la réputation de la maison depuis plus de 15
          ans — une cuisine française généreuse, inspirée des traditions
          alsaciennes.
        </p>
      </div>
    </header>

    <nav class="cat-bar" aria-label="Catégories de la carte">
      <div class="container cat-bar-inner">
        {menu.map((c) => <a href={`#${c.id}`}>{c.short}</a>)}
      </div>
    </nav>

    <section class="carte-page section-pad">
      <div class="container">
        {
          groups.map((g) => (
            <section class="menu-group">
              <h2 class="group-title">{g.title}</h2>
              <MenuList categories={g.cats} />
            </section>
          ))
        }

        <p class="carte-foot">
          Prix en francs Pacifique (CFP) · Cuisine faite maison
        </p>
        <div class="back">
          <a href="/#carte" class="btn btn-ghost">← Retour à l'accueil</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <MobileBar />
</Layout>

<style>
  .carte-hero {
    background: linear-gradient(150deg, var(--brown), #2f1d12);
    color: var(--cream);
    padding-top: clamp(120px, 16vh, 165px);
    padding-bottom: clamp(40px, 6vw, 64px);
    text-align: center;
  }
  .carte-hero .eyebrow {
    color: var(--gold-soft);
    justify-content: center;
  }
  .carte-hero h1 {
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    margin: 0.5rem 0 0.9rem;
  }
  .carte-hero-sub {
    color: rgba(247, 240, 227, 0.85);
    max-width: 620px;
    margin-inline: auto;
    font-size: 1.05rem;
  }

  /* Barre de catégories — sticky, minimaliste, sans pastilles */
  .cat-bar {
    position: sticky;
    top: 54px;
    z-index: 40;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
  }
  .cat-bar-inner {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    overflow-x: auto;
    padding-block: 0.95rem;
  }
  .cat-bar a {
    flex: none;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--ink-soft);
    white-space: nowrap;
    transition: color 0.2s ease;
  }
  .cat-bar a:hover {
    color: var(--wine);
  }
  .cat-bar a:not(:first-child)::before {
    content: '•';
    margin: 0 0.95rem;
    color: var(--gold);
  }

  .carte-page {
    background: var(--cream);
  }
  .menu-group + .menu-group {
    margin-top: clamp(48px, 7vw, 88px);
  }
  .group-title {
    text-align: center;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 3rem);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink);
    margin-bottom: clamp(22px, 3vw, 36px);
  }

  .carte-foot {
    text-align: center;
    margin-top: clamp(40px, 6vw, 72px);
    color: var(--muted);
    font-size: 0.86rem;
    letter-spacing: 0.04em;
  }
  .back {
    text-align: center;
    margin-top: 1.8rem;
  }
</style>
